#!/usr/bin/env bash
set -euo pipefail

# scanlan
# Usage:
#   ./scanlan
#   ./scanlan 10.10.10.0/24
#   ./scanlan --maxtime
#   ./scanlan --maxtime 180
#   ./scanlan --maxtime 180 10.10.10.0/24

DEFAULT_MAXTIME=120
MAXTIME="$DEFAULT_MAXTIME"
NETWORK=""

HAS_ARPING=0
command -v arping >/dev/null 2>&1 && HAS_ARPING=1

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Error: missing command '$1'" >&2
    exit 1
  }
}

if [[ -t 1 ]]; then
  C_CYAN=$'\033[38;5;51m'
  C_MAGENTA=$'\033[38;5;213m'
  C_GREEN=$'\033[38;5;82m'
  C_YELLOW=$'\033[38;5;214m'
  C_RED=$'\033[38;5;196m'
  C_GRAY=$'\033[38;5;240m'
  C_BOLD=$'\033[1m'
  C_RESET=$'\033[0m'
else
  C_CYAN="" C_MAGENTA="" C_GREEN="" C_YELLOW="" C_RED=""
  C_GRAY="" C_BOLD="" C_RESET=""
fi

message() {
  local color="$1"
  shift
  printf '%s%s%s\n' "$color" "$*" "$C_RESET"
}

repeat_char() {
  local char="$1"
  local count="$2"
  local output=""
  while ((count-- > 0)); do
    output+="$char"
  done
  printf '%s' "$output"
}

print_step_title() {
  local step="$1"
  local title="$2"
  local subtitle="$3"

  local heading="STEP $step · $title"
  local width=${#heading}
  ((${#subtitle} > width)) && width=${#subtitle}

  echo
  printf '%s%s%s%s\n' "$C_MAGENTA" "$C_BOLD" "$heading" "$C_RESET"
  printf '%s\n' "$subtitle"
  printf '%s' "$C_CYAN"
  repeat_char '─' "$width"
  printf '%s\n' "$C_RESET"
}

print_table() {
  local headers_line="$1"
  local caps_line="$2"
  local -a rows headers caps widths fields
  local row value border i

  mapfile -t rows
  IFS='|' read -r -a headers <<< "$headers_line"
  IFS='|' read -r -a caps <<< "$caps_line"

  for ((i = 0; i < ${#headers[@]}; i++)); do
    widths[i]=${#headers[i]}
  done

  for row in "${rows[@]}"; do
    [[ -n "${row//|/}" ]] || continue
    IFS='|' read -r -a fields <<< "$row"
    for ((i = 0; i < ${#headers[@]}; i++)); do
      value="${fields[i]:-}"
      ((${#value} > widths[i])) && widths[i]=${#value}
      ((widths[i] > caps[i])) && widths[i]=${caps[i]}
    done
  done

  draw_table_border() {
    local left="$1" middle="$2" right="$3" line
    printf '%s%s' "$C_CYAN" "$left"
    for ((i = 0; i < ${#headers[@]}; i++)); do
      line="$(repeat_char '─' $((widths[i] + 2)))"
      printf '%s' "$line"
      ((i + 1 < ${#headers[@]})) && printf '%s' "$middle"
    done
    printf '%s%s\n' "$right" "$C_RESET"
  }

  draw_table_border '╭' '┬' '╮'
  printf '%s│%s' "$C_CYAN" "$C_RESET"
  for ((i = 0; i < ${#headers[@]}; i++)); do
    printf ' %s%s%-*.*s%s %s│%s' \
      "$C_BOLD" "$C_CYAN" "${widths[i]}" "${widths[i]}" "${headers[i]}" \
      "$C_RESET" "$C_CYAN" "$C_RESET"
  done
  echo
  draw_table_border '├' '┼' '┤'

  for row in "${rows[@]}"; do
    if [[ -z "${row//|/}" ]]; then
      draw_table_border '├' '┼' '┤'
      continue
    fi
    IFS='|' read -r -a fields <<< "$row"
    printf '%s│%s' "$C_CYAN" "$C_RESET"
    for ((i = 0; i < ${#headers[@]}; i++)); do
      value="${fields[i]:-}"
      printf ' %-*.*s %s│%s' \
        "${widths[i]}" "${widths[i]}" "$value" "$C_CYAN" "$C_RESET"
    done
    echo
  done
  draw_table_border '╰' '┴' '╯'
}

interactive_select() {
  local mode="$1"
  local header="$2"
  local preselected="$3"
  shift 3
  local -a options=("$@") selected=()
  local cursor=0 key sequence redraw=0 lines option marker prefix i

  [[ -r /dev/tty ]] || {
    message "$C_RED" "Interactive selection requires a terminal." >&2
    return 1
  }

  for ((i = 0; i < ${#options[@]}; i++)); do
    selected[i]=0
    if [[ "$mode" == "multi" && ",$preselected," == *",${options[i]},"* ]]; then
      selected[i]=1
    fi
  done
  lines=$((${#options[@]} + 2))

  while true; do
    ((redraw == 1)) && printf '\033[%dA' "$lines" >&2
    printf '\r\033[K%s%s%s\n' "$C_BOLD" "$header" "$C_RESET" >&2
    printf '\r\033[K%s\n' \
      "↑/↓: move · Space: toggle · Enter: confirm" >&2
    for ((i = 0; i < ${#options[@]}; i++)); do
      prefix='  '
      ((i == cursor)) && prefix='> '
      marker=''
      if [[ "$mode" == "multi" ]]; then
        marker='[ ] '
        ((selected[i] == 1)) && marker='[x] '
      fi
      option="${options[i]}"
      if ((i == cursor)); then
        printf '\r\033[K%s%s%s%s%s\n' \
          "$C_CYAN" "$prefix" "$marker" "$option" "$C_RESET" >&2
      elif ((selected[i] == 1)); then
        printf '\r\033[K%s%s%s%s%s\n' \
          "$C_GREEN" "$prefix" "$marker" "$option" "$C_RESET" >&2
      else
        printf '\r\033[K%s%s%s\n' "$prefix" "$marker" "$option" >&2
      fi
    done
    redraw=1

    IFS= read -rsn1 key < /dev/tty || return 1
    if [[ "$key" == $'\e' ]]; then
      IFS= read -rsn2 -t 0.1 sequence < /dev/tty || sequence=""
      case "$sequence" in
        '[A') ((cursor > 0)) && cursor=$((cursor - 1)) ;;
        '[B') ((cursor + 1 < ${#options[@]})) && cursor=$((cursor + 1)) ;;
      esac
    elif [[ "$key" == " " && "$mode" == "multi" ]]; then
      selected[cursor]=$((1 - selected[cursor]))
    elif [[ -z "$key" ]]; then
      break
    fi
  done

  if [[ "$mode" == "single" ]]; then
    printf '%s\n' "${options[cursor]}"
  else
    for ((i = 0; i < ${#options[@]}; i++)); do
      ((selected[i] == 1)) && printf '%s\n' "${options[i]}"
    done
  fi
  return 0
}

for cmd in nmap awk ip mktemp sort timeout; do
  require_cmd "$cmd"
done

TMP_FILE="$(mktemp)"
SCAN_STATUS_FILE="$(mktemp)"
ALL_NETWORK_SCAN_FILE="$(mktemp)"
DISCOVERED_HOSTS_FILE="$(mktemp)"
PORT_SCAN_FILE="$(mktemp)"
PORT_SCAN_STATUS_FILE="$(mktemp)"
ALL_PORT_SCAN_FILE="$(mktemp)"
cleanup() {
  rm -f "$TMP_FILE" "$SCAN_STATUS_FILE" "$ALL_NETWORK_SCAN_FILE" \
    "$DISCOVERED_HOSTS_FILE" "$PORT_SCAN_FILE" "$PORT_SCAN_STATUS_FILE" \
    "$ALL_PORT_SCAN_FILE"
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

usage() {
  cat <<'EOF'
Usage:
  ./scanlan
  ./scanlan 10.10.10.0/24
  ./scanlan --maxtime
  ./scanlan --maxtime 180
  ./scanlan --maxtime 180 10.10.10.0/24

Options:
  --maxtime           Open a chooser for max scan time
  --maxtime <sec>     Set max scan time directly (60, 120, 180, 240, 300)
  -h, --help          Show this help
EOF
}

is_valid_maxtime() {
  case "${1:-}" in
    60|120|180|240|300) return 0 ;;
    *) return 1 ;;
  esac
}

choose_maxtime() {
  local selected
  selected="$(interactive_select single "Select maximum scan time" "" \
    "60 seconds" "120 seconds" "180 seconds" "240 seconds" "300 seconds")"
  awk '{print $1}' <<< "$selected"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --maxtime)
        if [[ $# -gt 1 && "$2" =~ ^[0-9]+$ ]]; then
          if ! is_valid_maxtime "$2"; then
            message "$C_RED$C_BOLD" "Invalid max time: $2"
            message "$C_GRAY" "Allowed values: 60, 120, 180, 240, 300"
            exit 1
          fi
          MAXTIME="$2"
          shift 2
        else
          MAXTIME="$(choose_maxtime)"
          shift
        fi
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        if [[ -z "$NETWORK" ]]; then
          NETWORK="$1"
          shift
        else
          message "$C_RED$C_BOLD" "Unexpected argument: $1"
          usage
          exit 1
        fi
        ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Network discovery
# ---------------------------------------------------------------------------

get_networks() {
  ip -o -4 addr show up scope global | awk '
    {
      iface=$2
      cidr=$4
      print iface "|" cidr
    }
  ' | sort -u
}

# Derive the .1 probe IP from a CIDR (e.g. 192.168.1.5/24 → 192.168.1.1)
cidr_probe_ip() {
  local cidr="$1"
  local ip="${cidr%/*}"
  # Replace last octet with 1
  printf '%s.1\n' "${ip%.*}"
}

# Extract local IP from CIDR (strip prefix)
cidr_local_ip() {
  printf '%s\n' "${1%/*}"
}

# ---------------------------------------------------------------------------
# Precheck
# ---------------------------------------------------------------------------

# Runs precheck for one network and stores result fields in globals:
#   PC_IFACE, PC_CIDR, PC_LOCAL_IP, PC_ROUTE_IF, PC_ROUTE_SRC,
#   PC_GATEWAY, PC_STATUS, PC_NOTE
run_precheck_for_network() {
  local iface="$1"
  local cidr="$2"

  PC_IFACE="$iface"
  PC_CIDR="$cidr"
  PC_LOCAL_IP="$(cidr_local_ip "$cidr")"
  PC_ROUTE_IF="N/A"
  PC_ROUTE_SRC="N/A"
  PC_GATEWAY="N/A"
  PC_STATUS="UNREACHABLE"
  PC_NOTE=""

  local probe_ip
  probe_ip="$(cidr_probe_ip "$cidr")"

  # Get routing info
  local route_out
  route_out="$(ip route get "$probe_ip" 2>/dev/null || true)"

  if [[ -z "$route_out" ]]; then
    PC_NOTE="No route to probe IP $probe_ip"
    return
  fi

  PC_ROUTE_IF="$(awk '/dev/{for(i=1;i<=NF;i++) if($i=="dev") print $(i+1)}' <<< "$route_out" | head -1)"
  PC_ROUTE_SRC="$(awk '/src/{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' <<< "$route_out" | head -1)"

  # Try to find gateway from route table for this iface
  PC_GATEWAY="$(ip route show dev "$iface" 2>/dev/null \
    | awk '/default/{print $3; exit}')"
  [[ -z "$PC_GATEWAY" ]] && \
    PC_GATEWAY="$(ip route show 2>/dev/null \
      | awk -v iface="$iface" '/default/ && $0~iface {print $3; exit}')"
  [[ -z "$PC_GATEWAY" ]] && PC_GATEWAY="N/A"

  # Validate route points to the right interface
  if [[ -z "$PC_ROUTE_IF" || "$PC_ROUTE_IF" != "$iface" ]]; then
    PC_STATUS="LIMITED"
    PC_NOTE="Route goes through ${PC_ROUTE_IF:-unknown}, not $iface"
    return
  fi

  # Try ARP probe if arping available
  if [[ "$HAS_ARPING" -eq 1 ]]; then
    if sudo arping -c 1 -w 1 -I "$iface" "$probe_ip" >/dev/null 2>&1; then
      PC_STATUS="READY"
      PC_NOTE="ARP response from $probe_ip"
    else
      PC_STATUS="LIMITED"
      PC_NOTE="No ARP response from $probe_ip (may still be scannable)"
    fi
  else
    PC_STATUS="LIMITED"
    PC_NOTE="arping not available — ARP probe skipped"
  fi
}

# Print precheck rows supplied as pipe-separated values on stdin.
print_precheck_table() {
  message "$C_MAGENTA$C_BOLD" "Network Precheck"
  print_table \
    "INTERFACE|NETWORK|LOCAL IP|ROUTE IF|ROUTE SRC|GATEWAY|STATUS|NOTE" \
    "18|20|18|16|18|18|14|52"
}

# Run precheck on all active networks, print reports, store results.
# Populates:
#   PRECHECK_ENTRIES  — array of "iface|cidr|status" strings
run_all_prechecks() {
  PRECHECK_ENTRIES=()
  local table_rows=()

  local found=0
  while IFS='|' read -r iface cidr; do
    [[ -n "${iface:-}" && -n "${cidr:-}" ]] || continue
    found=1
    run_precheck_for_network "$iface" "$cidr"
    PRECHECK_ENTRIES+=("${iface}|${cidr}|${PC_STATUS}")
    table_rows+=("${PC_IFACE}|${PC_CIDR}|${PC_LOCAL_IP}|${PC_ROUTE_IF}|${PC_ROUTE_SRC}|${PC_GATEWAY}|${PC_STATUS}|${PC_NOTE:-—}")
  done < <(get_networks)

  if [[ $found -eq 0 ]]; then
    message "$C_RED$C_BOLD" "No active IPv4 networks found."
    exit 1
  fi

  printf '%s\n' "${table_rows[@]}" | print_precheck_table
}

# ---------------------------------------------------------------------------
# Network selection
# ---------------------------------------------------------------------------

choose_network_from_precheck() {
  local options=()
  local ready_options=()

  for entry in "${PRECHECK_ENTRIES[@]}"; do
    IFS='|' read -r iface cidr status <<< "$entry"
    local option="${iface}  ${cidr}  [${status}]"
    options+=("$option")
    if [[ "$status" == "READY" ]]; then
      ready_options+=("$option")
    fi
  done

  local selected ready_csv
  ready_csv="$(IFS=,; echo "${ready_options[*]}")"
  selected="$(interactive_select multi \
    "Select networks — Space: toggle · Enter: scan" \
    "$ready_csv" "${options[@]}")"

  # Extract one CIDR per selected row (second field).
  awk '{print $2}' <<< "$selected"
}

# If user passed a network manually, find it in precheck entries and show
# its report, or warn if not found.
handle_manual_network() {
  local target="$1"
  local matched_iface="" matched_cidr="" matched_status=""

  for entry in "${PRECHECK_ENTRIES[@]}"; do
    IFS='|' read -r iface cidr status <<< "$entry"
    if [[ "$cidr" == "$target" ]]; then
      matched_iface="$iface"
      matched_cidr="$cidr"
      matched_status="$status"
      break
    fi
  done

  if [[ -n "$matched_cidr" ]]; then
    echo
    message "$C_MAGENTA$C_BOLD" "Precheck for selected network:"
    run_precheck_for_network "$matched_iface" "$matched_cidr"
    printf '%s\n' \
      "${PC_IFACE}|${PC_CIDR}|${PC_LOCAL_IP}|${PC_ROUTE_IF}|${PC_ROUTE_SRC}|${PC_GATEWAY}|${PC_STATUS}|${PC_NOTE:-—}" \
      | print_precheck_table
  else
    echo
    message "$C_YELLOW$C_BOLD" \
      "Warning: $target was not detected as a local network."
    message "$C_GRAY" \
      "Proceeding with scan anyway — results may be limited."
  fi
}

# ---------------------------------------------------------------------------
# Scanning
# ---------------------------------------------------------------------------

scan_network() {
  local network="$1"

  sudo nmap -sn -n -T4 --max-retries 1 --host-timeout 8s "$network" 2>/dev/null | awk '
    function emit_host() {
      if (ip != "") {
        printf "%-15s %-20s %-30s\n", ip, mac, vendor
        fflush()
      }
    }
    /Nmap scan report for / {
      emit_host()
      ip=$NF
      mac="N/A"
      vendor="N/A"
    }
    /MAC Address: / {
      mac=$3
      vendor=$0
      sub(/^.*MAC Address: [^ ]+ \(/, "", vendor)
      sub(/\)$/, "", vendor)
    }
    END {
      emit_host()
    }
  '
}

run_scan_with_timeout() {
  local network="$1"
  local maxtime="$2"
  local tmp_file="$3"
  local status_file="$4"

  if timeout "${maxtime}s" bash -c \
      "$(declare -f scan_network); scan_network \"\$1\" > \"\$2\"" \
      _ "$network" "$tmp_file"; then
    echo "ok" > "$status_file"
  else
    local status=$?
    if [[ $status -eq 124 ]]; then
      echo "timeout" > "$status_file"
    else
      echo "error:$status" > "$status_file"
    fi
  fi
}

run_scan_with_countdown() {
  local network="$1"
  local maxtime="$2"
  local tmp_file="$3"
  local status_file="$4"
  local scan_number="$5"
  local scan_total="$6"
  local scan_pid start_time elapsed remaining live_hosts

  bash -c "$(declare -f scan_network); $(declare -f run_scan_with_timeout); \
    run_scan_with_timeout \"\$1\" \"\$2\" \"\$3\" \"\$4\"" \
    _ "$network" "$maxtime" "$tmp_file" "$status_file" &
  scan_pid=$!
  start_time=$SECONDS

  while kill -0 "$scan_pid" 2>/dev/null; do
    elapsed=$((SECONDS - start_time))
    remaining=$((maxtime - elapsed))
    ((remaining < 0)) && remaining=0
    live_hosts=0
    if [[ -s "$tmp_file" ]]; then
      live_hosts="$(wc -l < "$tmp_file" | tr -d ' ')"
    fi
    printf '\r\033[KScanning %s (%d/%d) — hosts found: %d — stopping in %ds' \
      "$network" "$scan_number" "$scan_total" "$live_hosts" "$remaining"
    sleep 1
  done

  wait "$scan_pid" || true
  printf '\r\033[KScan finished for %s (%d/%d).\n' \
    "$network" "$scan_number" "$scan_total"
}

append_network_scan_results() {
  local network="$1"
  local scan_result="$2"
  local tmp_file="$3"
  local status_label ip mac vendor

  case "$scan_result" in
    ok) status_label="COMPLETED" ;;
    timeout) status_label="TIMEOUT" ;;
    error:*) status_label="ERROR ${scan_result#error:}" ;;
  esac

  if [[ -s "$ALL_NETWORK_SCAN_FILE" ]]; then
    printf '%s\n' '||||' >> "$ALL_NETWORK_SCAN_FILE"
  fi

  if [[ -s "$tmp_file" ]]; then
    while read -r ip mac vendor; do
      printf '%s|%s|%s|%s|%s\n' \
        "$network" "$ip" "$mac" "$vendor" "$status_label"
    done < "$tmp_file" >> "$ALL_NETWORK_SCAN_FILE"
  else
    printf '%s|-|-|NO HOSTS|%s\n' "$network" "$status_label" \
      >> "$ALL_NETWORK_SCAN_FILE"
  fi
}

print_combined_network_scan_report() {
  local network_total="$1"
  local host_total
  host_total="$(awk -F '|' '$2 != "" && $2 != "-" {count++} END {print count + 0}' \
    "$ALL_NETWORK_SCAN_FILE")"

  echo
  message "$C_MAGENTA$C_BOLD" "Network Scan Report"
  message "$C_CYAN" \
    "Networks scanned: $network_total · Hosts found: $host_total · Max time per network: ${MAXTIME}s"
  echo
  print_table \
    "NETWORK|IP ADDRESS|MAC ADDRESS|VENDOR|STATUS" \
    "22|18|20|32|14" \
    < "$ALL_NETWORK_SCAN_FILE"
}

choose_hosts_for_port_scan() {
  local select_all_label="Select all discovered IPs"
  local options=("$select_all_label")
  local network ip selected selected_line select_all=0

  while IFS='|' read -r network ip; do
    [[ -n "${network:-}" && -n "${ip:-}" ]] || continue
    options+=("$ip  [$network]")
  done < <(sort -t '|' -k2,2 -u "$DISCOVERED_HOSTS_FILE")

  selected="$(interactive_select multi \
    "Select IPs — Space: toggle · Enter: scan ports" "" "${options[@]}")"

  while IFS= read -r selected_line; do
    if [[ "$selected_line" == "$select_all_label" ]]; then
      select_all=1
      break
    fi
  done <<< "$selected"

  if [[ $select_all -eq 1 ]]; then
    printf '%s\n' "${options[@]:1}"
  elif [[ -n "$selected" ]]; then
    printf '%s\n' "$selected"
  fi
  return 0
}

run_port_scan() {
  local ip="$1"
  local maxtime="$2"
  local output_file="$3"
  local status_file="$4"

  set -o pipefail

  if timeout "${maxtime}s" sudo nmap \
      -sS -n -T4 --max-retries 1 --host-timeout 30s "$ip" 2>/dev/null \
      | awk '
          /^[0-9]+\/tcp[[:space:]]/ && $2 == "open" {
            split($1, port_info, "/")
            printf "%s|%s|%s|%s\n", port_info[1], port_info[2], $2, $3
            fflush()
          }
        ' > "$output_file"; then
    echo "ok" > "$status_file"
  else
    local status=$?
    if [[ $status -eq 124 ]]; then
      echo "timeout" > "$status_file"
    else
      echo "error:$status" > "$status_file"
    fi
  fi
}

run_port_scan_with_countdown() {
  local ip="$1"
  local maxtime="$2"
  local output_file="$3"
  local status_file="$4"
  local scan_number="$5"
  local scan_total="$6"
  local scan_pid start_time elapsed remaining open_ports

  bash -c "$(declare -f run_port_scan); \
    run_port_scan \"\$1\" \"\$2\" \"\$3\" \"\$4\"" \
    _ "$ip" "$maxtime" "$output_file" "$status_file" &
  scan_pid=$!
  start_time=$SECONDS

  while kill -0 "$scan_pid" 2>/dev/null; do
    elapsed=$((SECONDS - start_time))
    remaining=$((maxtime - elapsed))
    ((remaining < 0)) && remaining=0
    open_ports=0
    if [[ -s "$output_file" ]]; then
      open_ports="$(wc -l < "$output_file" | tr -d ' ')"
    fi
    printf '\r\033[KScanning ports on %s (%d/%d) — open: %d — stopping in %ds' \
      "$ip" "$scan_number" "$scan_total" "$open_ports" "$remaining"
    sleep 1
  done

  wait "$scan_pid" || true
  printf '\r\033[KPort scan finished for %s (%d/%d).\n' \
    "$ip" "$scan_number" "$scan_total"
}

print_combined_port_scan_report() {
  local host_total="$1"

  echo
  message "$C_MAGENTA$C_BOLD" "Port Scan Report"
  message "$C_CYAN" \
    "Hosts scanned: $host_total · TCP ports: 1,000 most common · Max time per host: ${MAXTIME}s"
  echo
  print_table \
    "HOST|PORT|PROTOCOL|STATE|SERVICE" \
    "18|10|12|18|28" \
    < "$ALL_PORT_SCAN_FILE"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

parse_args "$@"

# --- Precheck phase ---------------------------------------------------------

print_step_title "1" "NETWORK PRECHECK" \
  "Check local interfaces, routes, gateways, and connectivity"

declare -a PRECHECK_ENTRIES
run_all_prechecks

echo

# --- Network selection ------------------------------------------------------

print_step_title "2" "HOST DISCOVERY" \
  "Select networks and discover active devices"

declare -a NETWORKS
if [[ -z "$NETWORK" ]]; then
  mapfile -t NETWORKS < <(choose_network_from_precheck)
else
  handle_manual_network "$NETWORK"
  NETWORKS=("$NETWORK")
fi

if [[ ${#NETWORKS[@]} -eq 0 ]]; then
  message "$C_RED$C_BOLD" "No networks selected."
  exit 1
fi

echo

# --- Scan phase -------------------------------------------------------------

sudo -v

SCAN_TOTAL=${#NETWORKS[@]}
SCAN_NUMBER=0
for network in "${NETWORKS[@]}"; do
  SCAN_NUMBER=$((SCAN_NUMBER + 1))
  run_scan_with_countdown \
    "$network" "$MAXTIME" "$TMP_FILE" "$SCAN_STATUS_FILE" \
    "$SCAN_NUMBER" "$SCAN_TOTAL"

  SCAN_RESULT="$(cat "$SCAN_STATUS_FILE")"
  append_network_scan_results "$network" "$SCAN_RESULT" "$TMP_FILE"
  awk -v network="$network" '{print network "|" $1}' "$TMP_FILE" \
    >> "$DISCOVERED_HOSTS_FILE"
done

print_combined_network_scan_report "$SCAN_TOTAL"

# --- Optional port scan phase ----------------------------------------------

if [[ -s "$DISCOVERED_HOSTS_FILE" ]]; then
  print_step_title "3" "TCP PORT SCAN" \
    "Select discovered IPs and inspect their common ports"
  declare -a SELECTED_HOSTS
  mapfile -t SELECTED_HOSTS < <(choose_hosts_for_port_scan)

  if [[ ${#SELECTED_HOSTS[@]} -gt 0 ]]; then
    PORT_SCAN_TOTAL=${#SELECTED_HOSTS[@]}
    PORT_SCAN_NUMBER=0
    for SELECTED_HOST in "${SELECTED_HOSTS[@]}"; do
      PORT_SCAN_NUMBER=$((PORT_SCAN_NUMBER + 1))
      SELECTED_IP="$(awk '{print $1}' <<< "$SELECTED_HOST")"
      run_port_scan_with_countdown \
        "$SELECTED_IP" "$MAXTIME" "$PORT_SCAN_FILE" \
        "$PORT_SCAN_STATUS_FILE" "$PORT_SCAN_NUMBER" "$PORT_SCAN_TOTAL"

      PORT_SCAN_RESULT="$(cat "$PORT_SCAN_STATUS_FILE")"
      if [[ -s "$ALL_PORT_SCAN_FILE" ]]; then
        printf '%s\n' '||||' >> "$ALL_PORT_SCAN_FILE"
      fi

      if [[ -s "$PORT_SCAN_FILE" ]]; then
        awk -v ip="$SELECTED_IP" '{print ip "|" $0}' "$PORT_SCAN_FILE" \
          >> "$ALL_PORT_SCAN_FILE"
      fi

      case "$PORT_SCAN_RESULT" in
        ok)
          if [[ ! -s "$PORT_SCAN_FILE" ]]; then
            printf '%s|-|-|NO OPEN PORTS|-\n' "$SELECTED_IP" \
              >> "$ALL_PORT_SCAN_FILE"
          fi
          ;;
        timeout)
          printf '%s|-|-|TIMEOUT|-\n' "$SELECTED_IP" \
            >> "$ALL_PORT_SCAN_FILE"
          ;;
        error:*)
          printf '%s|-|-|ERROR %s|-\n' \
            "$SELECTED_IP" "${PORT_SCAN_RESULT#error:}" \
            >> "$ALL_PORT_SCAN_FILE"
          ;;
      esac
    done

    print_combined_port_scan_report "$PORT_SCAN_TOTAL"
  else
    message "$C_GRAY" "Port scan skipped."
  fi
else
  message "$C_YELLOW" "No hosts were found; port scan selection skipped."
fi
